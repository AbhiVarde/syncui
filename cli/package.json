{
  "name": "@abhivarde/syncui",
  "version": "2.0.1",
  "description": "Add Sync UI components and blocks to your project with a single command, like shadcn/ui.",
  "bin": {
    "syncui": "bin/syncui.js"
  },
  "main": "bin/syncui.js",
  "files": [
    "bin",
    "src",
    "registry"
  ],
  "scripts": {
    "build:registry": "node scripts/build-registry.js ..",
    "build:variants": "node scripts/build-variants.js ..",
    "build": "npm run build:registry && npm run build:variants"
  },
  "keywords": [
    "syncui",
    "ui",
    "components",
    "react",
    "mui",
    "cli"
  ],
  "author": "AbhiVarde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbhiVarde/syncui.git",
    "directory": "cli"
  },
  "homepage": "https://syncui.design",
  "type": "commonjs",
  "dependencies": {
    "commander": "^15.0.0"
  }
}
